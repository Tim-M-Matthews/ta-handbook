# REQUIRED for Auth.js. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Astro dev default port
AUTH_URL=http://localhost:4321

# Outside Vercel, set true so Auth.js trusts the Host header.
# AUTH_TRUST_HOST=true

# Google OAuth — used in production/preview builds whenever DISABLE_AUTH is not true.
# Authorized redirect URI in Google Cloud Console must include: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# When "true", skips Google sign-in and uses a synthetic admin session (all pages visible).
# Use for Cloudflare preview / deploy testing without OAuth secrets. Do not set in real production if the site must stay private.
DISABLE_AUTH=false

# JSON map: email (lowercase keys) -> role string or array of strings.
# Local `astro dev` signs you in as tim.matthews@triangleact.com by default (no Google); roles come from this map (same as production).
# Example:
# HANDBOOK_ROLE_MAP={"tim.matthews@triangleact.com":["admin","clinical"],"peer@triangleact.com":"staff"}
HANDBOOK_ROLE_MAP={}

# Optional: during `astro dev` only, impersonate a different email (must exist in HANDBOOK_ROLE_MAP for accurate RBAC; otherwise dev grants admin with a console warning).
# DEV_AUTH_EMAIL=other@triangleact.com
