# Generate with: openssl rand -base64 32
AUTH_SECRET=

# App URL (local dev)
AUTH_URL=http://localhost:3000

# Google OAuth (Auth.js infers AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# JSON map: email (lowercase keys) -> role string or array of strings.
# Example:
# HANDBOOK_ROLE_MAP={"you@triangleact.com":["admin","clinical"],"peer@triangleact.com":"staff"}
HANDBOOK_ROLE_MAP={}
