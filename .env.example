# REQUIRED for Auth.js. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Astro dev default port
AUTH_URL=http://localhost:4321

# Optional: canonical site URL for /sitemap.xml <loc> values in production (https://your-domain.com)
# PUBLIC_SITE_URL=https://your-handbook.example.com

# Outside Vercel, set true so Auth.js trusts the Host header.
# AUTH_TRUST_HOST=true

# Google OAuth — used in production/preview builds whenever DISABLE_AUTH is not true.
# Authorized redirect URI in Google Cloud Console must include: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# When "true", skips Google sign-in and uses a synthetic admin session (all pages visible).
# Use for Cloudflare preview / deploy testing without OAuth secrets. Do not set in real production if the site must stay private.
DISABLE_AUTH=false

# Who may sign in and their roles is defined in src/lib/handbook-role-map.ts (committed to git).

# Bookmarks (production): bind a KV namespace to the Worker as BOOKMARKS_KV. Create with:
#   npx wrangler kv namespace create BOOKMARKS_KV
# Then add kv_namespaces in wrangler.jsonc or set the binding in the Cloudflare Worker dashboard.

# Optional: during `astro dev` only, impersonate a different email (must exist in handbook-role-map.ts for accurate RBAC; otherwise dev grants admin with a console warning).
# DEV_AUTH_EMAIL=other@triangleact.com
# Optional: during `astro dev` only, override the displayed name in the header (defaults from the email local-part).
# DEV_AUTH_NAME=Pat Example
