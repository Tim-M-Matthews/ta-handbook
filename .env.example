# REQUIRED for Auth.js. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Astro dev default port
AUTH_URL=http://localhost:4321

# Outside Vercel, set true so Auth.js trusts the Host header.
# AUTH_TRUST_HOST=true

# Google OAuth — only used when sign-in is enabled (see DISABLE_AUTH below).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# When "true", skips Google sign-in and uses a synthetic admin session (all pages visible).
# Use for Cloudflare Pages preview / deploy testing without OAuth secrets. Do not set in production if the site must stay private.
DISABLE_AUTH=false

# JSON map: email (lowercase keys) -> role string or array of strings.
# Example:
# HANDBOOK_ROLE_MAP={"you@triangleact.com":["admin","clinical"],"peer@triangleact.com":"staff"}
HANDBOOK_ROLE_MAP={}
