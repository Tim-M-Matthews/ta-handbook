---
import "../styles/global.css";
import { authBypassLabel, isAuthBypassed } from "../lib/dev-auth";

interface Props {
  title?: string;
}

const { title = "Triangle ACT Handbook" } = Astro.props;
const bypass = isAuthBypassed();
const session = Astro.locals.session;

if (!bypass && !session?.user) {
  return Astro.redirect("/login");
}

const email = bypass ? authBypassLabel() : (session!.user?.email ?? "");
const roles = bypass ? ["admin"] : (session!.user?.roles ?? []);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/file.svg" />
    <title>{title}</title>
  </head>
  <body>
    <div class="shell">
      <header class="shell__header">
        <div class="shell__brand">
          <a href="/">Triangle ACT Handbook</a>
        </div>
        <form class="shell__search" action="/search" method="get" role="search">
          <label class="sr-only" for="global-search">Search handbook</label>
          <input
            id="global-search"
            name="q"
            type="search"
            placeholder="Search…"
            autocomplete="off"
          />
          <button type="submit" class="btn btn--small">Search</button>
        </form>
        <div class="shell__user">
          <span
            class="shell__email"
            title={bypass ? "Google OAuth not used while auth is bypassed" : roles.join(", ")}
            >{email}</span>
          {
            bypass ? null : (
              <button type="button" class="btn btn--ghost" id="signout">
                Sign out
              </button>
            )
          }
        </div>
      </header>
      <main class="shell__main">
        <slot />
      </main>
    </div>
    {
      bypass ? null : (
        <script>
          import { signOut } from "auth-astro/client";
          document.getElementById("signout")?.addEventListener("click", () => {
            void signOut({ callbackUrl: "/login" } as never);
          });
        </script>
      )
    }
  </body>
</html>
