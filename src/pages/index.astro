---
import HandbookLayout from "../layouts/HandbookLayout.astro";
import { isAuthBypassed, isLocalDevPersona } from "../lib/dev-auth";
import { listMetaForRoles } from "../lib/content";

const session = Astro.locals.session!;
const roles = session.user?.roles ?? [];
const pages = listMetaForRoles(roles);
const byCategory = new Map<string, typeof pages>();
for (const p of pages) {
  const list = byCategory.get(p.category) ?? [];
  list.push(p);
  byCategory.set(p.category, list);
}
const categories = [...byCategory.keys()].sort((a, b) => a.localeCompare(b));
const bypass = isAuthBypassed();
const localPersona = isLocalDevPersona();
---

<HandbookLayout title="Handbook">
  <h1 class="h1">Handbook</h1>
  <p class="lead">
    {
      bypass ? (
        localPersona ? (
          <>
            <strong>Local dev:</strong> signed in as{" "}
            <strong>{session.user?.email ?? "—"}</strong> (no Google OAuth). Page access
            follows <code>HANDBOOK_ROLE_MAP</code> like production. Roles:{" "}
            <strong>{roles.length ? roles.join(", ") : "—"}</strong>. Edit{" "}
            <code>content/pages</code> and save—refresh to view changes. Optional: set{" "}
            <code>DEV_AUTH_EMAIL</code> in <code>.env</code> to impersonate another user.
          </>
        ) : (
          <>
            <strong>Preview / deploy test:</strong> <code>DISABLE_AUTH</code> is set—Google
            sign-in is off and you see every page. Remove it for production. Edit{" "}
            <code>content/pages</code> and redeploy to publish.
          </>
        )
      ) : (
        <>
          Pages shown here match your roles:{" "}
          <strong>{roles.length ? roles.join(", ") : "—"}</strong>. Edit{" "}
          <code>content/pages</code> and redeploy to publish updates.
        </>
      )
    }
  </p>
  {
    categories.length === 0 ? (
      <p class="empty">
        No pages available yet. Add markdown under <code>content/pages</code>.
      </p>
    ) : (
      categories.map((cat) => (
        <section class="cat" aria-labelledby={`cat-${cat}`}>
          <h2 id={`cat-${cat}`} class="cat__title">
            {cat}
          </h2>
          <ul class="cat__list" role="list">
            {(byCategory.get(cat) ?? []).map((p) => (
              <li class="cat__item">
                <a class="cat__link" href={`/p/${p.slug}`}>
                  {p.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    )
  }
</HandbookLayout>
