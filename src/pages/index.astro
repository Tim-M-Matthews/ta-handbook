---
import HandbookLayout from "../layouts/HandbookLayout.astro";
import { categoryDefForId } from "../lib/categories";
import { categoryChromeFieldsForRow, categoryChromeSwatch } from "../lib/category-chrome";
import { isAuthBypassed, isLocalDevPersona } from "../lib/dev-auth";
import {
  categoryExistsInSite,
  getAllCategoryIndexIds,
  getAllSubcategoryIndexPairs,
  homeSectionsForRoles,
  listMetaForCategory,
  listMetaForRoles,
  listMetaForSubcategory,
} from "../lib/content";
import { userCanViewPage } from "../lib/roles";
import { subcategoryTitleForPair } from "../lib/subcategories";

function utf8ToBase64(str: string): string {
  const bytes = new TextEncoder().encode(str);
  let bin = "";
  for (let i = 0; i < bytes.length; i++) bin += String.fromCharCode(bytes[i]!);
  return btoa(bin);
}

const session = Astro.locals.session!;
const roles = session.user?.roles ?? [];
const sections = homeSectionsForRoles(roles);
const bypass = isAuthBypassed();
const localPersona = isLocalDevPersona();

type BookmarkCrumbRow = {
  categoryLabel: string;
  subcategoryLabel?: string;
  categoryId: string;
  chromeBrand?: string;
  chromeOnBrand?: string;
};
const bookmarkCrumbLookup: Record<string, BookmarkCrumbRow> = {};

for (const m of listMetaForRoles(roles)) {
  const row: BookmarkCrumbRow = {
    categoryLabel: m.categoryLabel,
    categoryId: m.categoryId,
    ...categoryChromeFieldsForRow(m.categoryId),
  };
  if (m.subcategoryLabel) row.subcategoryLabel = m.subcategoryLabel;
  bookmarkCrumbLookup[m.slug] = row;
}

for (const { categoryId, subcategoryId } of getAllSubcategoryIndexPairs()) {
  if (listMetaForSubcategory(roles, categoryId, subcategoryId).length === 0) continue;
  const cat = categoryDefForId(categoryId);
  if (!userCanViewPage(roles, cat.roles)) continue;
  bookmarkCrumbLookup[`c/${categoryId}/${subcategoryId}`] = {
    categoryLabel: cat.title,
    subcategoryLabel: subcategoryTitleForPair(categoryId, subcategoryId),
    categoryId,
    ...categoryChromeFieldsForRow(categoryId),
  };
}

for (const categoryId of getAllCategoryIndexIds()) {
  if (!categoryExistsInSite(categoryId)) continue;
  const cat = categoryDefForId(categoryId);
  if (!userCanViewPage(roles, cat.roles)) continue;
  if (listMetaForCategory(roles, categoryId).length === 0) continue;
  bookmarkCrumbLookup[`c/${categoryId}`] = {
    categoryLabel: cat.title,
    categoryId,
    ...categoryChromeFieldsForRow(categoryId),
  };
}

const bookmarkCrumbsB64 = utf8ToBase64(JSON.stringify(bookmarkCrumbLookup));
---

<HandbookLayout title="Triangle ACT Handbook">
  <div class="home-bookmarks-bar">
    <button type="button" class="btn btn--small" id="handbook-bookmarks-open">
      Open bookmarks
    </button>
  </div>
  <div
    id="handbook-bookmarks-modal"
    class="handbook-bookmarks-modal"
    hidden
    role="dialog"
    aria-modal="true"
    aria-labelledby="handbook-bookmarks-modal-title"
    data-handbook-bookmark-crumbs-b64={bookmarkCrumbsB64}
  >
    <div class="handbook-bookmarks-modal__panel">
      <div class="handbook-bookmarks-modal__head">
        <h2 id="handbook-bookmarks-modal-title" class="handbook-bookmarks-modal__title">Bookmarks</h2>
        <div class="handbook-bookmarks-modal__head-actions">
          <button type="button" class="btn btn--small" id="handbook-bookmarks-edit" aria-pressed="false">
            Edit bookmarks
          </button>
          <button
            type="button"
            class="btn btn--small"
            id="handbook-bookmarks-modal-close"
            aria-label="Close bookmarks"
          >
            Close
          </button>
        </div>
      </div>
      <div id="handbook-bookmarks-modal-list" class="handbook-bookmarks-modal__list"></div>
    </div>
  </div>
  {
    bypass && localPersona ? (
      <aside
        class="dev-callout"
        id="local-dev-callout"
        role="status"
        aria-labelledby="local-dev-callout-title"
        data-dismiss-storage="triangle-act-handbook:local-dev-banner"
      >
        <div class="dev-callout__head">
          <strong class="dev-callout__title" id="local-dev-callout-title">
            Local dev
          </strong>
          <button
            type="button"
            class="dev-callout__close"
            data-dismiss-close
            aria-label="Dismiss local dev notice"
          >
            Dismiss
          </button>
        </div>
        <div class="dev-callout__body">
          <p>
            You're signed in as{" "}
            <strong>{(session.user?.name?.trim() || session.user?.email) ?? "—"}</strong>
            {session.user?.name?.trim() && session.user?.email ? (
              <span> ({session.user.email})</span>
            ) : null}
            .
          </p>
          <p>Google OAuth is not used on this machine.</p>
          <p>
            Page access follows <code>src/lib/handbook-role-map.ts</code>, the same as
            production after Google sign-in.
          </p>
          <p>
            <strong>Roles:</strong> {roles.length ? roles.join(", ") : "—"}
          </p>
          <p>
            Edit files under <code>content/pages</code>, then <strong>refresh the browser</strong>{" "}
            to see changes.
          </p>
          <p>
            Optional: set <code>DEV_AUTH_EMAIL</code> or <code>DEV_AUTH_NAME</code> in <code>.env</code>{" "}
            to impersonate another user or label.
          </p>
        </div>
      </aside>
    ) : bypass ? (
      <aside
        class="dev-callout dev-callout--preview"
        id="preview-auth-callout"
        role="status"
        aria-labelledby="preview-auth-callout-title"
        data-dismiss-storage="triangle-act-handbook:preview-auth-banner"
      >
        <div class="dev-callout__head">
          <strong class="dev-callout__title" id="preview-auth-callout-title">
            Preview / deploy test
          </strong>
          <button
            type="button"
            class="dev-callout__close"
            data-dismiss-close
            aria-label="Dismiss preview notice"
          >
            Dismiss
          </button>
        </div>
        <div class="dev-callout__body">
          <p>
            <code>DISABLE_AUTH</code> is set. Google sign-in is off and you can see every page.
          </p>
          <p>Remove it for real production if the site must stay private.</p>
          <p>
            Edit <code>content/pages</code> and redeploy to publish.
          </p>
        </div>
      </aside>
    ) : null
  }
  {
    sections.length === 0 ? (
      <p class="empty">
        No pages available yet. Add markdown under <code>content/pages</code>.
      </p>
    ) : (
      <ul class="home-cat-grid" role="list">
        {sections.map((sec) => {
          const catChromeBrand = categoryChromeSwatch(sec.categoryId);
          return (
          <li
            class:list={[
              "home-cat-grid__cell",
              catChromeBrand && "home-cat-grid__cell--cat-chrome",
            ]}
            data-category={sec.categoryId}
            style={catChromeBrand ? { "--cat-chrome-brand": catChromeBrand } : undefined}
          >
            <a
              class="home-cat-grid__btn"
              href={`/c/${encodeURIComponent(sec.categoryId)}`}
            >
              <span class="home-cat-grid__label">{sec.categoryLabel}</span>
              {sec.categoryDescription ? (
                <span class="home-cat-grid__desc">{sec.categoryDescription}</span>
              ) : null}
            </a>
          </li>
          );
        })}
      </ul>
    )
  }
  {
    bypass ? (
      <script is:inline>
        (function () {
          document.querySelectorAll("[data-dismiss-storage]").forEach(function (el) {
            var key = el.getAttribute("data-dismiss-storage");
            var btn = el.querySelector("[data-dismiss-close]");
            if (!key || !btn) return;
            try {
              if (localStorage.getItem(key)) el.hidden = true;
            } catch (_) {}
            btn.addEventListener("click", function () {
              try {
                localStorage.setItem(key, "1");
              } catch (_) {}
              el.hidden = true;
            });
          });
        })();
      </script>
    ) : null
  }
</HandbookLayout>
