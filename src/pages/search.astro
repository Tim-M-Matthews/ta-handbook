---
import HandbookLayout from "../layouts/HandbookLayout.astro";
import Fuse from "fuse.js";
import { searchRowsForRoles } from "../lib/content";

const session = Astro.locals.session!;
const roles = session.user?.roles ?? [];
const q = Astro.url.searchParams.get("q")?.trim() ?? "";
const rows = searchRowsForRoles(roles);
const fuse = new Fuse(rows, {
  keys: ["title", "categoryLabel", "excerpt"],
  threshold: 0.35,
  ignoreLocation: true,
});
const results = q ? fuse.search(q).map((r) => r.item) : [];
---

<HandbookLayout title="Search">
  <h1 class="h1">Search</h1>
  <form class="shell__search" action="/search" method="get" role="search">
    <label class="sr-only" for="search-q">Query</label>
    <input
      id="search-q"
      name="q"
      type="search"
      value={q}
      placeholder="Search titles and text…"
      autocomplete="off"
    />
    <button type="submit" class="btn btn--small btn--primary">Search</button>
  </form>
  <p class="search-meta">
    {
      q
        ? `${results.length} result${results.length === 1 ? "" : "s"}`
        : "Enter a search term."
    }
  </p>
  {
    q && results.length === 0 ? (
      <p class="empty">No matches among pages you can access.</p>
    ) : q ? (
      <ul class="search-list" role="list">
        {results.map((hit) => (
          <li class="search-hit">
            <h2 class="search-hit__title">
              <a href={`/p/${hit.slug}`}>{hit.title}</a>
            </h2>
            <div class="search-hit__cat">{hit.categoryLabel}</div>
            <p class="search-hit__excerpt">{hit.excerpt}</p>
          </li>
        ))}
      </ul>
    ) : null
  }
</HandbookLayout>
